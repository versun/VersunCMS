<div class="statuses-admin">     
  <% @posts.each do |post| %>

    <div class="row-actions">
        <%= link_to "view", status_path(post) %> |
        <%= link_to "delete", status_path(post),
            data: { turbo_method: :delete, turbo_confirm: "Delete permanently?" } %> |
        <%= link_to post.text, edit_status_path(post) %>
    </div>
  <% end %>
  <hr>
  <%= will_paginate @posts %>
</div>

