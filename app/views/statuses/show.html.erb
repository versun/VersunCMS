<% content_for :title do %>
  Status | <%= site_settings[:title] %>
<% end %>
<article>
  <small style="color:grey">created: <%= @status.created_at.to_date %>, updated: <%= @status.updated_at.to_date %></small>
  <%= @status.text %>
</article>

<% if @status.social_media_posts.present? %>
  <br>
  <b>Discussion on </b>
  <% if mastodon_url = @status.social_media_posts.find_by(platform: 'mastodon')&.url %>
    <%= link_to "Mastodon", mastodon_url, target: "_blank" %>,
  <% end %>
  <% if twitter_url = @status.social_media_posts.find_by(platform: 'twitter')&.url %>
    <%= link_to "X", twitter_url, target: "_blank" %>,
  <% end %>
  <% if bluesky_url = @status.social_media_posts.find_by(platform: 'bluesky')&.url %>
    <%= link_to "Bluesky", bluesky_url, target: "_blank" %>.
  <% end %>
<% end %>
<hr>
<div class="giscus"></div>
<%= raw site_settings[:giscus] %>
